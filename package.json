{
  "name": "hitachi2",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "typescript": "^5.9.3",
      "@types/bun": "^1.3.11",
      "@orpc/server": "^1.13.13",
      "@orpc/openapi": "^1.13.13",
      "@orpc/zod": "^1.13.13",
      "better-auth": "^1.5.6",
      "@prisma/client": "^7.6.0",
      "@orpc/client": "^1.13.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:ci": "turbo run build --affected",
    "test": "turbo run test",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @hitachi2/db db:push",
    "db:studio": "turbo -F @hitachi2/db db:studio",
    "db:seed": "turbo -F @hitachi2/db db:seed",
    "db:generate": "turbo -F @hitachi2/db db:generate",
    "db:migrate": "turbo -F @hitachi2/db db:migrate",
    "db:start": "turbo -F @hitachi2/db db:start",
    "db:watch": "turbo -F @hitachi2/db db:watch",
    "db:stop": "turbo -F @hitachi2/db db:stop",
    "db:down": "turbo -F @hitachi2/db db:down",
    "test:e2e": "turbo -F @hitachi2/e2e test:e2e",
    "check": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@hitachi2/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@hitachi2/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
